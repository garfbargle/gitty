# Copy to .env.macos-signing.local and fill in values.
# .env.macos-signing.local is gitignored — never commit secrets.

# --- Code signing (required for notarization) ---
# Create a "Developer ID Application" certificate at developer.apple.com, install the .cer,
# then run: security find-identity -v -p codesigning
APPLE_SIGNING_IDENTITY="Developer ID Application: Codi Bonney (35KCXSVT5V)"
APPLE_TEAM_ID="35KCXSVT5V"

# --- Notarization: pick ONE auth method ---

# Option A — Apple ID (simplest for local builds)
APPLE_ID="you@example.com"
# App-specific password from https://appleid.apple.com/account/manage
APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# Option B — App Store Connect API key (better for CI)
# APPLE_API_ISSUER="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# APPLE_API_KEY="XXXXXXXXXX"
# APPLE_API_KEY_PATH="$HOME/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8"

# Only needed if your Apple ID belongs to multiple teams
# APPLE_PROVIDER_SHORT_NAME="YourTeamShortName"
